{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Seam Owner Registry Schema",
  "type": "object",
  "required": ["version", "seams"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string"
    },
    "governance_rule": {
      "type": "string"
    },
    "seams": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/seam"
      }
    },
    "reason_codes": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "definitions": {
    "seam": {
      "type": "object",
      "required": ["owner", "description", "canonical_doc"],
      "properties": {
        "owner": {
          "type": "string",
          "description": "The module slug that owns this seam"
        },
        "description": {
          "type": "string",
          "description": "What this seam covers"
        },
        "canonical_doc": {
          "type": "string",
          "description": "Path to the authoritative document"
        },
        "sections": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Section keys where this seam is defined"
        },
        "related_modules": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Modules that may reference but not own this seam"
        },
        "link_instruction": {
          "type": "string",
          "description": "Guidance for non-owner modules"
        }
      }
    }
  }
}
