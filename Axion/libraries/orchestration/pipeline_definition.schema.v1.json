{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "axion://schemas/orchestration/pipeline_definition.schema.v1.json",
  "title": "Axion Pipeline Definition Schema v1",
  "type": "object",
  "required": ["version", "pipeline_id", "description", "stages", "stage_order", "gates"],
  "properties": {
    "version": { "type": "string" },
    "pipeline_id": { "type": "string" },
    "description": { "type": "string" },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Stage" }
    },
    "stage_order": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "gates": {
      "type": "array",
      "items": { "$ref": "#/$defs/GatePoint" }
    },
    "activation_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/ActivationRule" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "Stage": {
      "type": "object",
      "required": ["stage_id", "name", "consumes", "produces", "outputs"],
      "properties": {
        "stage_id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "consumes": { "type": "array", "items": { "type": "string" } },
        "produces": { "type": "array", "items": { "type": "string" } },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/Output" }
        },
        "verification_commands": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "Output": {
      "type": "object",
      "required": ["artifact_id", "path", "role"],
      "properties": {
        "artifact_id": { "type": "string" },
        "path": { "type": "string" },
        "role": { "type": "string" },
        "schema_ref": { "type": "string" }
      },
      "additionalProperties": false
    },
    "GatePoint": {
      "type": "object",
      "required": ["gate_id", "after_stage_id"],
      "properties": {
        "gate_id": { "type": "string" },
        "after_stage_id": { "type": "string" },
        "before_stage_id": { "type": "string" },
        "required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "ActivationRule": {
      "type": "object",
      "required": ["rule_id", "when", "enable_stages"],
      "properties": {
        "rule_id": { "type": "string" },
        "when": { "type": "string" },
        "enable_stages": { "type": "array", "items": { "type": "string" } },
        "disable_stages": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  }
}
