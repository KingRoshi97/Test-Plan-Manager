{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "axion://schemas/orchestration/stage_report.schema.v1.json",
  "title": "Axion Stage Report Schema v1",
  "type": "object",
  "required": ["version", "run_id", "stage_id", "status", "started_at", "finished_at", "outputs", "notes"],
  "properties": {
    "version": { "type": "string" },
    "run_id": { "type": "string" },
    "stage_id": { "type": "string" },
    "status": { "enum": ["queued", "running", "gated", "failed", "released", "skipped"] },
    "started_at": { "type": "string" },
    "finished_at": { "type": "string" },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_id", "path"],
        "properties": {
          "artifact_id": { "type": "string" },
          "path": { "type": "string" },
          "hash": { "type": "string" },
          "bytes": { "type": "integer" }
        },
        "additionalProperties": false
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "notes": { "type": "array", "items": { "type": "string" } },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "pointers": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
