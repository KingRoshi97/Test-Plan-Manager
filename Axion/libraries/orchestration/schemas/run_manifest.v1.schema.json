{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "run_manifest.v1",
    "type": "object",
    "required": [
      "run_id",
      "created_at",
      "updated_at",
      "workspace_id",
      "project_id",
      "pipeline_ref",
      "pins",
      "runtime",
      "stage_timeline",
      "artifacts"
    ],
    "properties": {
      "run_id": { "type": "string", "pattern": "^RUN-[A-Z0-9]{6,}$" },

      "created_at": { "type": "string", "format": "date-time" },
      "updated_at": { "type": "string", "format": "date-time" },

      "workspace_id": { "type": "string", "pattern": "^WS-[A-Z0-9]{6,}$" },
      "project_id": { "type": "string", "pattern": "^PRJ-[A-Z0-9]{6,}$" },

      "pipeline_ref": {
        "type": "object",
        "required": ["pipeline_id", "version", "path"],
        "properties": {
          "pipeline_id": { "type": "string" },
          "version": { "type": "string" },
          "path": { "type": "string" },
          "hash": { "type": "string" }
        },
        "additionalProperties": false
      },

      "pins": {
        "type": "object",
        "required": ["pin_set_id", "pin_set_ref"],
        "properties": {
          "pin_set_id": { "type": "string" },
          "pin_set_ref": {
            "type": "object",
            "required": ["version", "path"],
            "properties": {
              "version": { "type": "string" },
              "path": { "type": "string" },
              "hash": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },

      "runtime": {
        "type": "object",
        "required": ["profile_id", "risk_class", "adapter_profile_id", "quota_effective"],
        "properties": {
          "profile_id": { "type": "string" },
          "risk_class": { "type": "string" },

          "adapter_profile_id": { "type": "string" },

          "quota_effective": {
            "type": "object",
            "description": "Snapshot of effective quota decision at run start",
            "additionalProperties": true
          },

          "policy_decisions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["decision_id", "hook_point", "outcome", "expires_at"],
              "properties": {
                "decision_id": { "type": "string" },
                "hook_point": { "type": "string" },
                "outcome": { "type": "string" },
                "expires_at": { "type": "string", "format": "date-time" }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": false
      },

      "stage_timeline": {
        "type": "array",
        "minItems": 1,
        "items": { "$ref": "#/$defs/stage_entry" }
      },

      "gates": {
        "type": "array",
        "items": { "$ref": "#/$defs/gate_entry" }
      },

      "artifacts": {
        "type": "array",
        "items": { "$ref": "#/$defs/artifact_entry" }
      },

      "events": {
        "type": "array",
        "description": "Append-only run events (resume, rerun, approvals, notifications)",
        "items": { "$ref": "#/$defs/run_event" }
      }
    },

    "$defs": {
      "stage_entry": {
        "type": "object",
        "required": ["stage_id", "status", "started_at"],
        "properties": {
          "stage_id": { "type": "string" },
          "status": { "type": "string", "enum": ["queued", "running", "succeeded", "failed", "paused", "skipped"] },
          "started_at": { "type": "string", "format": "date-time" },
          "ended_at": { "type": "string", "format": "date-time" },
          "report_ref": {
            "type": "object",
            "properties": { "path": { "type": "string" }, "hash": { "type": "string" } },
            "additionalProperties": false
          },
          "notes": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      },
      "gate_entry": {
        "type": "object",
        "required": ["gate_id", "status", "evaluated_at"],
        "properties": {
          "gate_id": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail", "warn"] },
          "evaluated_at": { "type": "string", "format": "date-time" },
          "gate_report_ref": {
            "type": "object",
            "properties": { "path": { "type": "string" }, "hash": { "type": "string" } },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },

      "artifact_entry": {
        "type": "object",
        "required": ["artifact_id", "contract_id", "path", "produced_by_stage"],
        "properties": {
          "artifact_id": { "type": "string", "minLength": 2 },
          "contract_id": { "type": "string", "minLength": 2 },
          "path": { "type": "string", "minLength": 2 },
          "hash": { "type": "string" },
          "produced_by_stage": { "type": "string" }
        },
        "additionalProperties": false
      },

      "run_event": {
        "type": "object",
        "required": ["event_type", "at"],
        "properties": {
          "event_type": {
            "type": "string",
            "enum": ["RUN_STARTED", "RUN_RESUMED", "STAGE_RERUN", "APPROVAL_GRANTED", "NOTIFICATION_SENT"]
          },
          "at": { "type": "string", "format": "date-time" },
          "data": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": false
      }
    },

    "additionalProperties": false
}
