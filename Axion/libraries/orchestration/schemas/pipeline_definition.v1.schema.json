{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "pipeline_definition.v1",
    "type": "object",
    "required": [
      "pipeline_id",
      "version",
      "stage_order",
      "stages",
      "created_at",
      "updated_at",
      "owner"
    ],
    "properties": {
      "pipeline_id": { "type": "string", "pattern": "^PIPE-[A-Z0-9_]+$" },
      "version": { "type": "string", "minLength": 1 },

     "stage_order": {
       "type": "array",
       "minItems": 1,
       "items": { "type": "string", "pattern": "^S\\d{1,2}_[A-Z0-9_]+$" }
     },

     "stages": {
       "type": "object",
       "additionalProperties": { "$ref": "#/$defs/stage_def" }
     },

     "gate_points": {
       "type": "array",
       "items": { "$ref": "#/$defs/gate_point" }
     },

     "created_at": { "type": "string", "format": "date-time" },
     "updated_at": { "type": "string", "format": "date-time" },
     "owner": { "type": "string", "minLength": 2 }
    },

    "$defs": {
      "stage_def": {
        "type": "object",
        "required": ["stage_id", "name", "consumes", "produces", "can_rerun", "failure_policy"],
        "properties": {
          "stage_id": { "type": "string", "pattern": "^S\\d{1,2}_[A-Z0-9_]+$" },
          "name": { "type": "string", "minLength": 2 },

          "consumes": {
            "type": "array",
            "items": { "type": "string", "minLength": 3 },
            "description": "References to stage IO contract IDs"
          },

          "produces": {
            "type": "array",
            "items": { "type": "string", "minLength": 3 },
            "description": "References to artifacts/contracts produced"
          },

          "activation": {
            "type": "object",
            "description": "Deterministic stage activation conditions",
            "properties": {
              "mode": { "type": "string", "enum": ["always", "conditional", "manual"] },
              "requires": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Named conditions evaluated from run context"
              }
            },
            "additionalProperties": false
          },

          "can_rerun": { "type": "boolean" },

          "failure_policy": {
            "type": "string",
            "enum": ["hard_stop", "retryable", "gate_pause"]
          }
        },
        "additionalProperties": false
      },

      "gate_point": {
        "type": "object",
        "required": ["after_stage", "gate_id"],
        "properties": {
          "after_stage": { "type": "string", "pattern": "^S\\d{1,2}_[A-Z0-9_]+$" },
          "gate_id": { "type": "string", "minLength": 3 },
          "severity": { "type": "string", "enum": ["hard_stop", "pause", "warn"] }
        },
        "additionalProperties": false
      }
    },

    "additionalProperties": false
}
