{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "axion://schemas/canonical/canonical_decision_report.v1",
  "title": "Canonical Decision Report",
  "description": "Schema for canonical decision report entries capturing entity resolution, provenance assignment, and downstream invalidation",
  "type": "object",
  "required": ["report_id", "resolution_version", "created_at", "decisions"],
  "properties": {
    "report_id": {
      "type": "string",
      "pattern": "^CDR-[A-Z0-9]{6,}$"
    },
    "resolution_version": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/decision_entry"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "decision_entry": {
      "type": "object",
      "required": [
        "decision_id",
        "entity_id",
        "decision_type",
        "timestamp",
        "resolution",
        "provenance_assignment",
        "downstream_invalidation",
        "verdict"
      ],
      "properties": {
        "decision_id": {
          "type": "string",
          "pattern": "^CDR-[A-Z0-9]{6,}-[0-9]+$"
        },
        "entity_id": {
          "type": "string",
          "pattern": "^E-[A-Z0-9]{6,}$"
        },
        "decision_type": {
          "type": "string",
          "enum": [
            "entity_resolution",
            "provenance_assignment",
            "merge",
            "split",
            "deprecation"
          ]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "resolution": {
          "$ref": "#/definitions/resolution_block"
        },
        "provenance_assignment": {
          "$ref": "#/definitions/provenance_block"
        },
        "downstream_invalidation": {
          "$ref": "#/definitions/invalidation_block"
        },
        "verdict": {
          "$ref": "#/definitions/verdict_block"
        }
      },
      "additionalProperties": false
    },
    "resolution_block": {
      "type": "object",
      "required": ["input_sources", "conflict_detected", "resolved_entity_snapshot"],
      "properties": {
        "input_sources": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "conflict_detected": {
          "type": "boolean"
        },
        "conflict_resolution_method": {
          "type": "string",
          "enum": ["priority_override", "merge", "operator_decision", "none"]
        },
        "resolved_entity_snapshot": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "provenance_block": {
      "type": "object",
      "required": ["assigned_class", "evidence"],
      "properties": {
        "previous_class": {
          "type": "string",
          "enum": ["hard_fact", "inferred_fact", "unresolved_unknown"]
        },
        "assigned_class": {
          "type": "string",
          "enum": ["hard_fact", "inferred_fact", "unresolved_unknown"]
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "inference_chain": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "invalidation_block": {
      "type": "object",
      "required": ["invalidated_artifacts", "invalidation_reason", "requires_recompute"],
      "properties": {
        "invalidated_artifacts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "invalidation_reason": {
          "type": "string",
          "minLength": 1
        },
        "requires_recompute": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["S5", "S6", "S7", "S8", "S9"]
          }
        }
      },
      "additionalProperties": false
    },
    "verdict_block": {
      "type": "object",
      "required": ["verdict", "rationale", "follow_up_required"],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["accepted", "deferred", "rejected", "escalated"]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "follow_up_required": {
          "type": "boolean"
        },
        "follow_up_action": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}