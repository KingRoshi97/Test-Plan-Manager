{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "axion://schemas/canonical/canonical_unit.v1",
  "title": "Canonical Unit",
  "description": "Schema for a governed canonical unit with provenance and downstream dependencies",
  "type": "object",
  "required": [
    "entity_id",
    "entity_type",
    "name",
    "provenance_class",
    "provenance_source",
    "downstream_dependencies",
    "last_resolved_at",
    "resolution_version"
  ],
  "properties": {
    "entity_id": {
      "type": "string",
      "pattern": "^E-[A-Z0-9]{6,}$"
    },
    "entity_type": {
      "type": "string",
      "enum": [
        "project",
        "domain",
        "capability",
        "component",
        "data_entity",
        "endpoint",
        "integration",
        "workflow",
        "requirement",
        "constraint",
        "risk"
      ]
    },
    "name": {
      "type": "string",
      "minLength": 2
    },
    "provenance_class": {
      "type": "string",
      "enum": ["hard_fact", "inferred_fact", "unresolved_unknown"]
    },
    "provenance_source": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/evidence_entry"
      },
      "minItems": 1
    },
    "downstream_dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "last_resolved_at": {
      "type": "string",
      "format": "date-time"
    },
    "resolution_version": {
      "type": "string",
      "minLength": 1
    },
    "attributes": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "definitions": {
    "evidence_entry": {
      "type": "object",
      "required": ["type", "ref"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["intake_field", "standard_clause", "inference_rule", "gap"]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "rule_id": {
          "type": "string"
        },
        "inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reason": {
          "type": "string"
        },
        "needed": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}