{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "canonical_spec.v1",
    "type": "object",
    "required": ["spec_id", "version", "entities", "relationships", "created_at", "owner"],
    "properties": {
      "spec_id": { "type": "string", "pattern": "^CAN-[A-Z0-9]{6,}$" },
      "version": { "type": "string", "minLength": 1 },

     "entities": {
       "type": "array",
       "minItems": 1,
       "items": { "$ref": "#/$defs/entity" }
     },

     "relationships": {
       "type": "array",
       "items": { "$ref": "#/$defs/relationship" }
     },

     "meta": {
       "type": "object",
       "description": "Optional run-scoped metadata (profile, stack hints, etc.)",
       "additionalProperties": true
     },

      "created_at": { "type": "string", "format": "date-time" },
      "owner": { "type": "string", "minLength": 2 }
    },

    "$defs": {
     "entity": {
       "type": "object",
       "required": ["entity_id", "type", "name"],
       "properties": {
         "entity_id": { "type": "string", "pattern": "^E-[A-Z0-9]{6,}$" },
         "type": {
           "type": "string",
           "enum": [
             "project",
             "domain",
             "capability",
             "component",
             "data_entity",
             "endpoint",
             "integration",
             "workflow",
             "requirement",
             "constraint",
             "risk"
           ]
         },
         "name": { "type": "string", "minLength": 2 },

         "attributes": {
           "type": "object",
           "description": "Type-specific fields (kept flexible but bounded by contracts in CAN-2/3)",
           "additionalProperties": true
         }
       },
       "additionalProperties": false
     },

     "relationship": {
       "type": "object",
       "required": ["rel_id", "type", "from", "to"],
       "properties": {
         "rel_id": { "type": "string", "pattern": "^R-[A-Z0-9]{6,}$" },
         "type": {
           "type": "string",
           "enum": [
             "contains",
             "depends_on",
             "exposes",
             "stores",
             "integrates_with",
             "satisfies",
             "constrained_by"
           ]
         },
         "from": { "type": "string", "pattern": "^E-[A-Z0-9]{6,}$" },
         "to": { "type": "string", "pattern": "^E-[A-Z0-9]{6,}$" },

         "attributes": {
           "type": "object",
           "additionalProperties": true
         }
       },
       "additionalProperties": false
     }
    },

    "additionalProperties": false
}
