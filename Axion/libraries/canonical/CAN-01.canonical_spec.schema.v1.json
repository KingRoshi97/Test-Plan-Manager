{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "axion://schemas/canonical/CAN-01.canonical_spec.schema.v1.json",
  "title": "CAN-01 — Canonical Spec Schema (v1)",
  "type": "object",
  "required": ["meta", "routing", "constraints", "entities", "rules", "unknowns", "index"],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "spec_id",
        "submission_id",
        "form_version_used",
        "schema_version_used",
        "ruleset_version_used",
        "spec_version",
        "created_at"
      ],
      "properties": {
        "spec_id": { "type": "string" },
        "submission_id": { "type": "string" },
        "form_version_used": { "type": "string" },
        "schema_version_used": { "type": "string" },
        "ruleset_version_used": { "type": "string" },
        "spec_version": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "additionalProperties": true
    },

    "routing": {
      "type": "object",
      "required": ["skill_level", "category", "type_preset", "build_target", "audience_context"],
      "properties": {
        "skill_level": { "type": "string" },
        "category": { "type": "string" },
        "type_preset": { "type": "string" },
        "build_target": { "type": "string" },
        "audience_context": { "type": "string" }
      },
      "additionalProperties": true
    },

    "constraints": {
      "type": "object",
      "required": ["stack_constraints", "security_constraints", "quality_constraints", "fixed_vs_configurable"],
      "properties": {
        "stack_constraints": { "type": "object" },
        "security_constraints": { "type": "object" },
        "quality_constraints": { "type": "object" },
        "design_constraints": { "type": "object" },
        "fixed_vs_configurable": {
          "type": "object",
          "additionalProperties": { "enum": ["fixed", "configurable"] }
        }
      },
      "additionalProperties": true
    },

    "entities": {
      "type": "object",
      "required": ["roles", "features", "workflows", "permissions", "screens", "data_objects", "operations", "integrations"],
      "properties": {
        "roles": {
          "type": "array",
          "items": { "$ref": "#/$defs/Role" }
        },
        "features": {
          "type": "array",
          "items": { "$ref": "#/$defs/Feature" }
        },
        "workflows": {
          "type": "array",
          "items": { "$ref": "#/$defs/Workflow" }
        },
        "permissions": {
          "type": "array",
          "items": { "$ref": "#/$defs/Permission" }
        },
        "screens": {
          "type": "array",
          "items": { "$ref": "#/$defs/Screen" }
        },
        "data_objects": {
          "type": "array",
          "items": { "$ref": "#/$defs/DataObject" }
        },
        "operations": {
          "type": "array",
          "items": { "$ref": "#/$defs/Operation" }
        },
        "integrations": {
          "type": "array",
          "items": { "$ref": "#/$defs/Integration" }
        }
      },
      "additionalProperties": true
    },

    "rules": {
      "type": "object",
      "required": ["definition_of_done", "acceptance_criteria"],
      "properties": {
        "definition_of_done": { "type": "string" },
        "must_always": { "type": "array", "items": { "type": "string" } },
        "must_never": { "type": "array", "items": { "type": "string" } },
        "must_pass_checks": { "type": "array", "items": { "type": "string" } },
        "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
        "rejection_conditions": { "type": "string" }
      },
      "additionalProperties": true
    },

    "unknowns": {
      "type": "array",
      "items": { "$ref": "axion://schemas/canonical/CAN-03.unknown.schema.v1.json" }
    },

    "index": {
      "type": "object",
      "required": [
        "roles_by_id",
        "features_by_id",
        "workflows_by_id",
        "permissions_by_id",
        "screens_by_id",
        "data_objects_by_id",
        "operations_by_id",
        "integrations_by_id",
        "cross_maps",
        "unknowns_by_id"
      ],
      "properties": {
        "roles_by_id": { "type": "object" },
        "features_by_id": { "type": "object" },
        "workflows_by_id": { "type": "object" },
        "permissions_by_id": { "type": "object" },
        "screens_by_id": { "type": "object" },
        "data_objects_by_id": { "type": "object" },
        "operations_by_id": { "type": "object" },
        "integrations_by_id": { "type": "object" },
        "unknowns_by_id": { "type": "object" },
        "cross_maps": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "Role": {
      "type": "object",
      "required": ["role_id", "name"],
      "properties": {
        "role_id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "primary_goal": { "type": "string" }
      },
      "additionalProperties": true
    },
    "Feature": {
      "type": "object",
      "required": ["feature_id", "name", "priority_tier"],
      "properties": {
        "feature_id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "priority_tier": { "enum": ["must", "nice", "future"] },
        "priority_rank": { "type": "number" }
      },
      "additionalProperties": true
    },
    "Workflow": {
      "type": "object",
      "required": ["workflow_id", "name", "actor_role_ref", "steps", "success_outcome"],
      "properties": {
        "workflow_id": { "type": "string" },
        "name": { "type": "string" },
        "actor_role_ref": { "type": "string" },
        "steps": { "type": "array", "items": { "type": "string" } },
        "success_outcome": { "type": "string" },
        "failure_states": { "type": "string" },
        "priority": { "type": "string" }
      },
      "additionalProperties": true
    },
    "Permission": {
      "type": "object",
      "required": ["perm_id", "role_ref", "allowed_capabilities"],
      "properties": {
        "perm_id": { "type": "string" },
        "role_ref": { "type": "string" },
        "allowed_capabilities": { "type": "array", "items": { "type": "string" } },
        "restricted_actions": { "type": "array", "items": { "type": "string" } },
        "approval_required_actions": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "Screen": {
      "type": "object",
      "required": ["screen_id", "name"],
      "properties": {
        "screen_id": { "type": "string" },
        "name": { "type": "string" },
        "purpose": { "type": "string" },
        "primary_actor_role_ref": { "type": "string" }
      },
      "additionalProperties": true
    },
    "DataObject": {
      "type": "object",
      "required": ["data_object_id", "name"],
      "properties": {
        "data_object_id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "fields": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    },
    "Operation": {
      "type": "object",
      "required": ["operation_id", "name"],
      "properties": {
        "operation_id": { "type": "string" },
        "name": { "type": "string" },
        "kind": { "type": "string" },
        "inputs": { "type": "array", "items": { "type": "string" } },
        "outputs": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "Integration": {
      "type": "object",
      "required": ["integration_id", "name"],
      "properties": {
        "integration_id": { "type": "string" },
        "name": { "type": "string" },
        "provider": { "type": "string" },
        "kind": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
