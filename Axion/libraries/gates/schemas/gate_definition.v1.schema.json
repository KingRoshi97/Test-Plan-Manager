{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "gate_definition.v1",
    "type": "object",
    "required": [
      "gate_id",
      "title",
      "severity",
      "predicates",
      "evidence_policy",
      "created_at",
      "updated_at",
      "owner"
    ],
    "properties": {
      "gate_id": { "type": "string", "pattern": "^G\\d+_[A-Z0-9_]+$" },
      "title": { "type": "string", "minLength": 3 },
      "severity": { "type": "string", "enum": ["hard_stop", "pause", "warn"] },
      "predicates": {
        "type": "array",
        "minItems": 1,
        "items": { "$ref": "#/$defs/predicate" }
      },
      "evidence_policy": {
        "type": "object",
        "required": ["mode"],
        "properties": {
          "mode": { "type": "string", "enum": ["minimal", "standard", "trace"] },
          "include_pointers": { "type": "boolean", "default": true },
          "include_diff": { "type": "boolean", "default": false },
          "include_verification_proof": { "type": "boolean", "default": true }
        },
        "additionalProperties": false
      },
      "override_hook": {
        "type": "object",
        "description": "If present, failing gate may request policy approval to override.",
        "required": ["hook_point"],
        "properties": {
          "hook_point": { "type": "string", "enum": ["GATE_OVERRIDE"] },
          "requires_reason": { "type": "boolean", "default": true }
        },
        "additionalProperties": false
      },
      "created_at": { "type": "string", "format": "date-time" },
      "updated_at": { "type": "string", "format": "date-time" },
      "owner": { "type": "string", "minLength": 2 }
    },
    "$defs": {
      "predicate": {
        "type": "object",
        "required": ["predicate_id", "expr", "message_on_fail"],
        "properties": {
          "predicate_id": { "type": "string", "pattern": "^PRED-[A-Z0-9]{4,}$" },
          "expr": { "type": "string", "minLength": 1, "description": "Gate DSL expression string" },
          "message_on_fail": { "type": "string", "minLength": 3 },
          "evidence_tags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Hints for what evidence to attach (paths, diffs, proofs)"
          }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
}
