{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "gate_eval_request.v1",
    "type": "object",
    "required": ["request_id", "run_id", "gate_id", "context_refs", "requested_at"],
    "properties": {
      "request_id": { "type": "string", "pattern": "^GATEREQ-[A-Z0-9]{6,}$" },
      "run_id": { "type": "string", "pattern": "^RUN-[A-Z0-9]{6,}$" },
      "gate_id": { "type": "string" },
      "context_refs": {
        "type": "object",
        "required": ["manifest_ref"],
        "properties": {
          "manifest_ref": { "type": "string", "minLength": 3 },
          "stage_reports": { "type": "array", "items": { "type": "string" } },
          "artifacts": { "type": "array", "items": { "type": "string" } },
          "proof_ledger_ref": { "type": "string" },
          "knowledge_selection_ref": { "type": "string" }
        },
        "additionalProperties": false
      },
      "trace_mode": { "type": "string", "enum": ["off", "on"], "default": "off" },
      "requested_at": { "type": "string", "format": "date-time" }
    },
    "additionalProperties": false
}
