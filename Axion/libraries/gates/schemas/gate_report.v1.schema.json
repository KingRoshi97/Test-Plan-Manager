{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "gate_report.v1",
    "type": "object",
    "required": [
      "run_id",
      "gate_id",
      "status",
      "evaluated_at",
      "failures",
      "evidence_policy",
      "summary"
    ],
    "properties": {
      "run_id": { "type": "string" },
      "gate_id": { "type": "string" },
      "status": { "type": "string", "enum": ["pass", "fail", "warn"] },
      "evaluated_at": { "type": "string", "format": "date-time" },
      "summary": {
        "type": "object",
        "required": ["failed_predicates", "notes"],
        "properties": {
          "failed_predicates": { "type": "integer", "minimum": 0 },
          "notes": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      },
      "evidence_policy": {
        "type": "object",
        "required": ["mode"],
        "properties": {
          "mode": { "type": "string", "enum": ["minimal", "standard", "trace"] }
        },
        "additionalProperties": false
      },
      "failures": {
        "type": "array",
        "items": { "$ref": "#/$defs/failure" }
      },
      "override": {
        "type": "object",
        "description": "Present when gate supports override or override was requested/granted",
        "properties": {
          "requested": { "type": "boolean" },
          "granted": { "type": "boolean" },
          "decision_id": { "type": "string" },
          "reason": { "type": "string" },
          "expires_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      },
      "trace_ref": {
        "type": "object",
        "description": "Present only when evidence_policy.mode == trace",
        "properties": {
          "path": { "type": "string" },
          "hash": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "$defs": {
      "failure": {
        "type": "object",
        "required": ["predicate_id", "message", "evidence_refs", "remediation"],
        "properties": {
          "predicate_id": { "type": "string" },
          "message": { "type": "string", "minLength": 3 },
          "evidence_refs": {
            "type": "array",
            "items": { "$ref": "#/$defs/evidence_ref" }
          },
          "remediation": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 3 }
          }
        },
        "additionalProperties": false
      },
      "evidence_ref": {
        "type": "object",
        "required": ["kind", "ref"],
        "properties": {
          "kind": { "type": "string", "enum": ["pointer", "diff", "proof", "snapshot"] },
          "ref": { "type": "string", "minLength": 3 },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
}
