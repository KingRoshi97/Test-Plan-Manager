{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "axion://schemas/maintenance/library_health_report.v1",
  "title": "Library Health Report",
  "type": "object",
  "required": [
    "report_id",
    "library_id",
    "assessed_at",
    "composite_score",
    "target_score",
    "health_status",
    "dimensions"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "description": "Unique identifier for this health report"
    },
    "library_id": {
      "type": "string",
      "description": "Identifier of the assessed library"
    },
    "assessed_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the assessment"
    },
    "composite_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Weighted composite health score"
    },
    "target_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Minimum acceptable health score for this library"
    },
    "health_status": {
      "type": "string",
      "enum": ["healthy", "degraded", "critical"],
      "description": "Derived status based on composite_score vs target_score"
    },
    "dimensions": {
      "type": "object",
      "required": [
        "structural_completeness",
        "doctrine_compliance",
        "schema_validity",
        "registry_integrity",
        "documentation_coverage"
      ],
      "properties": {
        "structural_completeness": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "doctrine_compliance": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "schema_validity": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "registry_integrity": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "documentation_coverage": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "findings_summary": {
      "type": "object",
      "properties": {
        "error_count": {
          "type": "integer",
          "minimum": 0
        },
        "warning_count": {
          "type": "integer",
          "minimum": 0
        },
        "info_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "run_id": {
      "type": "string",
      "description": "Maintenance run that produced this report"
    }
  }
}