{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0.0",
  "id": "intake_submission.v1",
  "type": "object",
  "required": ["submission_id", "form_ref", "submitted_at", "answers"],
  "properties": {
    "submission_id": { "type": "string", "pattern": "^SUB-[A-Z0-9]{6,}$" },
    "form_ref": {
      "type": "object",
      "required": ["form_id", "version"],
      "properties": {
        "form_id": { "type": "string" },
        "version": { "type": "string" }
      },
      "additionalProperties": false
    },
    "submitted_at": { "type": "string", "format": "date-time" },
    "actor": {
      "type": "object",
      "properties": {
        "actor_id": { "type": "string" },
        "role": { "type": "string" }
      },
      "additionalProperties": false
    },
    "answers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["field_id", "value"],
        "properties": {
          "field_id": { "type": "string" },
          "value": {},
          "raw_text": { "type": "string", "description": "Optional original user text for enums/normalization auditing" }
        },
        "additionalProperties": false
      }
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["attachment_id", "kind", "path"],
        "properties": {
          "attachment_id": { "type": "string", "pattern": "^ATT-[A-Z0-9]{6,}$" },
          "kind": { "type": "string", "enum": ["file", "zip", "url_ref"] },
          "path": { "type": "string" },
          "hash": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
