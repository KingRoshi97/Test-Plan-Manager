{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0.0",
  "id": "normalization_rules.v1",
  "type": "object",
  "required": ["rules_id", "schema_version", "rules"],
  "properties": {
    "rules_id": { "type": "string", "minLength": 3 },
    "schema_version": { "type": "string", "minLength": 1 },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["rule_id", "applies_to", "transform"],
        "properties": {
          "rule_id": { "type": "string", "pattern": "^NORM-[A-Z0-9_]+$" },
          "applies_to": {
            "type": "object",
            "required": ["field_ids"],
            "properties": {
              "field_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
            },
            "additionalProperties": false
          },
          "transform": {
            "type": "object",
            "required": ["kind"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "trim",
                  "collapse_whitespace",
                  "lowercase",
                  "uppercase",
                  "slugify",
                  "dedupe_sort",
                  "parse_csv_list"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
