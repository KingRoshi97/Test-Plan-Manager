{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "axion://schemas/intake/intake_unit.v1",
  "title": "Intake Unit",
  "description": "Schema for a governed intake unit representing a single intake field with its canonical mapping, standards applicability, and ambiguity classification.",
  "type": "object",
  "required": [
    "field_id",
    "label",
    "field_type",
    "required",
    "canonical_mapping",
    "ambiguity_class"
  ],
  "properties": {
    "field_id": {
      "type": "string",
      "pattern": "^F-[A-Z0-9_]+$",
      "description": "Stable field identifier"
    },
    "label": {
      "type": "string",
      "minLength": 2,
      "description": "Human-readable field label"
    },
    "field_type": {
      "type": "string",
      "enum": [
        "text",
        "textarea",
        "number",
        "boolean",
        "enum",
        "multi_enum",
        "date",
        "file_ref",
        "json"
      ]
    },
    "required": {
      "type": "boolean"
    },
    "enum_ref": {
      "type": "string",
      "description": "Reference to enum registry entry, required for enum/multi_enum types"
    },
    "canonical_mapping": {
      "type": "object",
      "required": ["canonical_field", "mapping_type", "transform"],
      "properties": {
        "canonical_field": {
          "type": "string",
          "description": "Dot-notation path to the canonical spec field"
        },
        "mapping_type": {
          "type": "string",
          "enum": ["direct", "derived", "conditional"]
        },
        "transform": {
          "type": "string",
          "enum": ["none", "lowercase", "slug", "alias_resolve"]
        },
        "source_fields": {
          "type": "array",
          "items": { "type": "string" },
          "description": "For derived mappings, the source field IDs"
        }
      },
      "additionalProperties": false
    },
    "standards_applicability": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of standard IDs or categories influenced by this field"
    },
    "ambiguity_class": {
      "type": "string",
      "enum": ["AMB-0", "AMB-1", "AMB-2", "AMB-3"],
      "description": "Ambiguity risk classification"
    },
    "normalization_rule": {
      "type": "string",
      "description": "Reference to the normalization rule applied to this field"
    },
    "deprecation_notice": {
      "type": "string",
      "description": "If deprecated, describes the deprecation and replacement"
    }
  },
  "additionalProperties": false
}