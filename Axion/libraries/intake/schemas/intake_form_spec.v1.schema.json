{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0.0",
  "id": "intake_form_spec.v1",
  "type": "object",
  "required": ["form_id", "version", "pages", "created_at", "updated_at", "owner"],
  "properties": {
    "form_id": { "type": "string", "pattern": "^FORM-[A-Z0-9_]+$" },
    "version": { "type": "string", "minLength": 1 },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/page" }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "owner": { "type": "string", "minLength": 2 }
  },
  "$defs": {
    "page": {
      "type": "object",
      "required": ["page_id", "title", "order", "fields"],
      "properties": {
        "page_id": { "type": "string", "pattern": "^PAGE-[A-Z0-9_]+$" },
        "title": { "type": "string", "minLength": 2 },
        "order": { "type": "integer", "minimum": 1 },
        "visibility": { "$ref": "#/$defs/visibility_rule" },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/field" }
        }
      },
      "additionalProperties": false
    },
    "field": {
      "type": "object",
      "required": ["field_id", "label", "type", "required"],
      "properties": {
        "field_id": { "type": "string", "pattern": "^F-[A-Z0-9_]+$" },
        "label": { "type": "string", "minLength": 2 },
        "type": {
          "type": "string",
          "enum": ["text", "textarea", "number", "boolean", "enum", "multi_enum", "date", "file_ref", "json"]
        },
        "required": { "type": "boolean" },
        "help_text": { "type": "string" },
        "enum_ref": { "type": "string", "description": "Required for enum/multi_enum" },
        "validations": {
          "type": "array",
          "items": { "$ref": "#/$defs/validation_rule" }
        },
        "visibility": { "$ref": "#/$defs/visibility_rule" }
      },
      "additionalProperties": false
    },
    "visibility_rule": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "enum": ["always", "conditional"] },
        "when": {
          "type": "array",
          "description": "List of conditions (ANDed). Each condition references a field_id and expected value.",
          "items": {
            "type": "object",
            "required": ["field_id", "op", "value"],
            "properties": {
              "field_id": { "type": "string" },
              "op": { "type": "string", "enum": ["==", "!=", "contains"] },
              "value": {}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "validation_rule": {
      "type": "object",
      "required": ["rule_id", "kind"],
      "properties": {
        "rule_id": { "type": "string", "pattern": "^VAL-[A-Z0-9_]+$" },
        "kind": {
          "type": "string",
          "enum": ["min_len", "max_len", "min", "max", "regex", "custom"]
        },
        "value": {},
        "message": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
