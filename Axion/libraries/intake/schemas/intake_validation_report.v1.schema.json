{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0.0",
  "id": "intake_validation_report.v1",
  "type": "object",
  "required": ["submission_id", "status", "errors", "warnings", "validated_at"],
  "properties": {
    "submission_id": { "type": "string" },
    "status": { "type": "string", "enum": ["pass", "fail", "warn"] },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/issue" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/issue" }
    },
    "validated_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "issue": {
      "type": "object",
      "required": ["code", "field_id", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^INT-[A-Z0-9_]+$" },
        "field_id": { "type": "string" },
        "message": { "type": "string" },
        "pointer": { "type": "string", "description": "Optional JSON pointer into submission record" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
