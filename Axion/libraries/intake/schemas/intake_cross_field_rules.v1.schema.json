{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0.0",
  "id": "intake_cross_field_rules.v1",
  "type": "object",
  "required": ["ruleset_id", "schema_version", "rules"],
  "properties": {
    "ruleset_id": { "type": "string", "minLength": 3 },
    "schema_version": { "type": "string", "minLength": 1 },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rule" }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "required": ["rule_id", "if", "then", "message"],
      "properties": {
        "rule_id": { "type": "string", "pattern": "^XVAL-[A-Z0-9_]+$" },
        "if": {
          "type": "array",
          "description": "AND conditions",
          "items": { "$ref": "#/$defs/condition" }
        },
        "then": {
          "type": "object",
          "anyOf": [
            { "required": ["require_fields"] },
            { "required": ["forbid_fields"] }
          ],
          "properties": {
            "require_fields": { "type": "array", "items": { "type": "string" } },
            "forbid_fields": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "message": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": false
    },
    "condition": {
      "type": "object",
      "required": ["field_id", "op", "value"],
      "properties": {
        "field_id": { "type": "string" },
        "op": { "type": "string", "enum": ["==", "!=", "contains", "exists"] },
        "value": {}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
