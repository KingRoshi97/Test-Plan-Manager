{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "axion://schemas/kit/kit_tree.schema.v1.json",
  "title": "Axion Kit Tree Contract Schema v1",
  "type": "object",
  "required": ["version", "root", "required_files", "required_folders", "slots"],
  "properties": {
    "version": { "type": "string" },
    "root": { "type": "string" },
    "required_files": { "type": "array", "items": { "type": "string" } },
    "required_folders": { "type": "array", "items": { "type": "string" } },
    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slot_id", "path", "description", "required"],
        "properties": {
          "slot_id": { "type": "string" },
          "path": { "type": "string" },
          "description": { "type": "string" },
          "required": { "type": "boolean" },
          "allowed_extensions": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
