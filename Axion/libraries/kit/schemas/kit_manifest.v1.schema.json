{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "kit_manifest.v1",
    "type": "object",
    "required": [
      "kit_id",
      "run_id",
      "kit_version",
      "created_at",
      "contents",
      "entrypoints"
    ],
    "properties": {
      "kit_id": { "type": "string", "pattern": "^KIT-[A-Z0-9]{6,}$" },
      "run_id": { "type": "string" },
      "kit_version": { "type": "string", "minLength": 1 },
      "created_at": { "type": "string", "format": "date-time" },
      "export_class": { "type": "string", "enum": ["internal", "external"] },
      "entrypoints": {
        "type": "object",
        "required": ["readme", "primary_artifact"],
        "properties": {
          "readme": { "type": "string" },
          "primary_artifact": { "type": "string" }
        },
        "additionalProperties": false
      },
      "contents": {
        "type": "array",
        "minItems": 1,
        "items": { "$ref": "#/$defs/item" }
      }
    },

    "$defs": {
      "item": {
        "type": "object",
        "required": ["path", "kind", "classification"],
        "properties": {
          "path": { "type": "string", "minLength": 2 },
          "kind": { "type": "string", "enum": ["doc", "artifact", "metadata", "script"] },
          "contract_id": { "type": "string", "description": "If this item corresponds to an artifact contract ID" },
          "source": {
            "type": "object",
            "properties": {
              "produced_by_stage": { "type": "string" },
              "artifact_ref": { "type": "string" }
            },
            "additionalProperties": false
          },
          "hash": { "type": "string" },
          "classification": {
            "type": "string",
            "enum": ["public", "internal_only", "restricted"]
          }
        },
        "additionalProperties": false
      }
    },

    "additionalProperties": false
}
