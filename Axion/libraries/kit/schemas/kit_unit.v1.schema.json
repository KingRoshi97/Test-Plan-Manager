{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "axion://schemas/kit/kit_unit.v1.schema.json",
  "title": "Kit Unit",
  "description": "Schema for a governed kit unit entry in the kit registry.",
  "type": "object",
  "required": [
    "unit_id",
    "name",
    "release_class",
    "version",
    "status"
  ],
  "properties": {
    "unit_id": {
      "type": "string",
      "pattern": "^kit-unit-[a-z0-9-]+$",
      "description": "Unique identifier for the kit unit."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable name of the kit unit."
    },
    "release_class": {
      "type": "string",
      "enum": ["dev", "candidate", "certified", "enterprise-ready"],
      "description": "Current release class tier of the kit unit."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the kit unit."
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated", "archived"],
      "description": "Lifecycle status of the kit unit."
    },
    "compatibility_matrix": {
      "type": "object",
      "description": "Declares compatible consumer platforms and versions.",
      "properties": {
        "platforms": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["platform", "min_version"],
            "properties": {
              "platform": { "type": "string" },
              "min_version": { "type": "string" },
              "max_version": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "proof_requirements": {
      "type": "object",
      "description": "Proof artifacts required for the current release class.",
      "properties": {
        "structural": { "type": "boolean" },
        "functional": { "type": "boolean" },
        "compliance": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["unit_id", "version_constraint"],
        "properties": {
          "unit_id": { "type": "string" },
          "version_constraint": { "type": "string" },
          "resolution": {
            "type": "string",
            "enum": ["pinned", "floating"]
          }
        },
        "additionalProperties": false
      }
    },
    "health_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Current composite health score."
    }
  },
  "additionalProperties": false
}
