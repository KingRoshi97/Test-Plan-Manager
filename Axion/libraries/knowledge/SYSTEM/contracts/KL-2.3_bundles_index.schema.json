{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0.0",
  "contract_id": "KL-2.3",
  "title": "BUNDLES_INDEX Registry Schema",
  "type": "object",
  "required": [
    "schema_version",
    "bundles"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "bundles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bundle"
      }
    }
  },
  "$defs": {
    "bundle": {
      "type": "object",
      "required": [
        "bundle_id",
        "title",
        "description",
        "selection_policy",
        "kids",
        "created_at",
        "updated_at",
        "owner"
      ],
      "properties": {
        "bundle_id": {
          "type": "string",
          "pattern": "^BUNDLE-[A-Z0-9_]+-\\d{4,}$"
        },
        "title": {
          "type": "string",
          "minLength": 3
        },
        "description": {
          "type": "string",
          "minLength": 3
        },
        "by_run_profile": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional: contexts like API, WEB, MOBILE, INFRA"
        },
        "by_risk_class": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional: PROTOTYPE, PROD, COMPLIANCE, etc."
        },
        "by_executor": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "internal_only",
              "internal_and_external"
            ]
          }
        },
        "by_stack_family": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "domains": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "kids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "selection_policy": {
          "type": "object",
          "required": [
            "mode",
            "cap"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "append",
                "override",
                "scoped"
              ]
            },
            "cap": {
              "type": "integer",
              "minimum": 1
            },
            "min_maturity": {
              "type": "string",
              "enum": [
                "draft",
                "reviewed",
                "verified",
                "golden"
              ]
            }
          },
          "additionalProperties": false
        },
        "deprecated_by": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date"
        },
        "updated_at": {
          "type": "string",
          "format": "date"
        },
        "owner": {
          "type": "string",
          "minLength": 2
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}