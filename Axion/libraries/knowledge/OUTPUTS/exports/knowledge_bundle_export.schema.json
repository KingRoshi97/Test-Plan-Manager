{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0.0",
  "title": "Knowledge Bundle Export",
  "description": "Schema for exported knowledge bundle artifacts",
  "type": "object",
  "required": [
    "schema_version",
    "bundle_id",
    "export_timestamp",
    "executor_type",
    "items",
    "total_items"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 3
    },
    "export_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "executor_type": {
      "type": "string",
      "enum": ["internal", "external"]
    },
    "filter_applied": {
      "type": "object",
      "properties": {
        "executor_access": {
          "type": "array",
          "items": { "type": "string" }
        },
        "min_maturity": {
          "type": "string",
          "enum": ["draft", "reviewed", "verified", "golden"]
        },
        "excluded_use_policies": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kid",
          "title",
          "type",
          "use_policy",
          "path",
          "maturity",
          "allowed_excerpt"
        ],
        "properties": {
          "kid": { "type": "string", "minLength": 8 },
          "title": { "type": "string", "minLength": 3 },
          "type": { "type": "string" },
          "use_policy": {
            "type": "string",
            "enum": ["pattern_only", "reusable_with_allowlist", "restricted_internal_only"]
          },
          "path": { "type": "string", "minLength": 5 },
          "maturity": {
            "type": "string",
            "enum": ["draft", "reviewed", "verified", "golden"]
          },
          "allowed_excerpt": {
            "type": "object",
            "required": ["max_words", "max_lines"],
            "properties": {
              "max_words": { "type": "integer", "minimum": 0 },
              "max_lines": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "total_items": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
