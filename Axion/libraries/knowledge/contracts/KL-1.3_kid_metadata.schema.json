{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0.0",
  "contract_id": "KL-1.3",
  "title": "KID Metadata (Frontmatter/JSON Header)",
  "type": "object",
  "required": [
    "kid",
    "title",
    "type",
    "pillar",
    "domains",
    "tags",
    "maturity",
    "use_policy",
    "executor_access",
    "license",
    "allowed_excerpt",
    "created_at",
    "updated_at",
    "owner"
  ],
  "properties": {
    "kid": {
      "type": "string",
      "description": "Stable Knowledge Item ID",
      "pattern": "^KID-[A-Z0-9_]+-[A-Z0-9_]+-[A-Z0-9_]+-\\d{4,}$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "type": {
      "type": "string",
      "enum": [
        "concept",
        "pattern",
        "procedure",
        "checklist",
        "reference",
        "pitfall",
        "example",
        "glossary_term"
      ]
    },
    "pillar": {
      "type": "string",
      "enum": [
        "IT_END_TO_END",
        "INDUSTRY_PLAYBOOKS",
        "LANGUAGES_AND_LIBRARIES"
      ]
    },
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "subdomains": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "maturity": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed",
        "verified",
        "golden"
      ]
    },
    "use_policy": {
      "type": "string",
      "enum": [
        "pattern_only",
        "reusable_with_allowlist",
        "restricted_internal_only"
      ]
    },
    "executor_access": {
      "type": "string",
      "enum": [
        "internal_only",
        "internal_and_external"
      ]
    },
    "license": {
      "type": "string",
      "minLength": 2
    },
    "allowed_excerpt": {
      "type": "object",
      "required": [
        "max_words",
        "max_lines"
      ],
      "properties": {
        "max_words": {
          "type": "integer",
          "minimum": 0
        },
        "max_lines": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "supersedes": {
      "type": "string",
      "description": "KID this item replaces (optional)"
    },
    "deprecated_by": {
      "type": "string",
      "description": "KID that replaces this item (optional)"
    },
    "created_at": {
      "type": "string",
      "format": "date"
    },
    "updated_at": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string",
      "minLength": 2
    }
  },
  "additionalProperties": false
}