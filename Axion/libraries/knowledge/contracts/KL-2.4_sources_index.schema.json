{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0.0",
  "contract_id": "KL-2.4",
  "title": "SOURCES_INDEX Registry Schema",
  "type": "object",
  "required": [
    "schema_version",
    "sources"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": [
        "source_id",
        "source_type",
        "title",
        "license",
        "attribution_required",
        "allowed_reuse_level",
        "created_at",
        "updated_at",
        "owner"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^SRC-[A-Z0-9_]+-\\d{4,}$"
        },
        "source_type": {
          "type": "string",
          "enum": [
            "internal_authored",
            "public_domain",
            "oss_docs",
            "third_party_docs",
            "academic_paper"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 3
        },
        "origin": {
          "type": "object",
          "description": "Where the material comes from.",
          "properties": {
            "publisher": {
              "type": "string"
            },
            "author": {
              "type": "string"
            },
            "year": {
              "type": "integer",
              "minimum": 0
            },
            "identifier": {
              "type": "string",
              "description": "Optional: doc id, ISBN, repo name, etc."
            }
          },
          "additionalProperties": false
        },
        "license": {
          "type": "string",
          "minLength": 2
        },
        "attribution_required": {
          "type": "boolean"
        },
        "allowed_reuse_level": {
          "type": "string",
          "enum": [
            "summary_only",
            "short_excerpts_only",
            "allowlisted_reuse",
            "full_reuse_per_license"
          ]
        },
        "reuse_constraints": {
          "type": "object",
          "properties": {
            "max_excerpt_words": {
              "type": "integer",
              "minimum": 0
            },
            "max_excerpt_lines": {
              "type": "integer",
              "minimum": 0
            },
            "notes": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "notes": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date"
        },
        "updated_at": {
          "type": "string",
          "format": "date"
        },
        "owner": {
          "type": "string",
          "minLength": 2
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}