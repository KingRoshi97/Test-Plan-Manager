{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "axion://schemas/planning/PLAN-03.build_plan.schema.v1.json",
  "title": "PLAN-03 — Build Plan Schema (v1)",
  "type": "object",
  "required": [
    "version",
    "run_id",
    "spec_id",
    "generated_at",
    "sequence",
    "notes"
  ],
  "properties": {
    "version": { "type": "string" },
    "run_id": { "type": "string" },
    "spec_id": { "type": "string" },
    "generated_at": { "type": "string" },
    "sequence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step_id", "unit_ref", "depends_on", "outputs"],
        "properties": {
          "step_id": { "type": "string" },
          "unit_ref": { "type": "string" },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "outputs": { "type": "array", "items": { "type": "string" } },
          "verification_commands": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
