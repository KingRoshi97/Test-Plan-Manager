{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "plan_coverage_rules.v1",
    "type": "object",
    "required": ["rules_id", "schema_version", "rules"],
    "properties": {
      "rules_id": { "type": "string", "minLength": 3 },
      "schema_version": { "type": "string", "minLength": 1 },
      "rules": {
        "type": "array",
        "minItems": 1,
        "items": { "$ref": "#/$defs/rule" }
      }
    },
    "$defs": {
      "rule": {
        "type": "object",
        "required": ["rule_id", "category", "requirement", "severity"],
        "properties": {
          "rule_id": { "type": "string", "pattern": "^COV-[A-Z0-9_\\-]+$" },
          "category": { "type": "string", "enum": ["entity", "template", "acceptance"] },
          "requirement": { "type": "string", "minLength": 3 },
          "severity": { "type": "string", "enum": ["must", "should"] }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
}
