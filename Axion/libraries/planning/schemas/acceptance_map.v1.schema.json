{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "acceptance_map.v1",
    "type": "object",
    "required": ["amap_id", "run_id", "requirements", "generated_at"],
    "properties": {
      "amap_id": { "type": "string", "pattern": "^AMAP-[A-Z0-9]{6,}$" },
      "run_id": { "type": "string" },
      "generated_at": { "type": "string", "format": "date-time" },
      "requirements": {
        "type": "array",
        "minItems": 1,
        "items": { "$ref": "#/$defs/req" }
      }
    },
    "$defs": {
      "req": {
        "type": "object",
        "required": ["requirement_id", "title", "acceptance_criteria"],
        "properties": {
          "requirement_id": { "type": "string", "minLength": 2 },
          "title": { "type": "string", "minLength": 3 },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/ac" }
          }
        },
        "additionalProperties": false
      },
      "ac": {
        "type": "object",
        "required": ["ac_id", "statement", "evidence"],
        "properties": {
          "ac_id": { "type": "string", "pattern": "^AC-[A-Z0-9]{6,}$" },
          "statement": { "type": "string", "minLength": 5 },
          "evidence": {
            "type": "object",
            "properties": {
              "artifact_contract_ids": { "type": "array", "items": { "type": "string" } },
              "proof_requirements": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
}
