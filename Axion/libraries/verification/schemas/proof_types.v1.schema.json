{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "proof_types.v1",
    "type": "object",
    "required": ["registry_id", "schema_version", "types"],
    "properties": {
      "registry_id": { "type": "string", "minLength": 3 },
      "schema_version": { "type": "string", "minLength": 1 },
      "types": {
        "type": "array",
        "minItems": 1,
        "items": { "$ref": "#/$defs/proof_type" }
      }
    },

    "$defs": {
      "proof_type": {
        "type": "object",
        "required": ["proof_type", "required_fields", "description"],
        "properties": {
          "proof_type": {
            "type": "string",
            "enum": ["command_run", "test_suite", "lint_check", "build_artifact", "security_scan", "manual_attestation"]
          },
          "description": { "type": "string", "minLength": 5 },
          "required_fields": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        },
        "additionalProperties": false
      }
    },

    "additionalProperties": false
}
