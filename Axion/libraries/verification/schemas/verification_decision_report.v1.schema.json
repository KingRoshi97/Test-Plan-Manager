{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "axion://schemas/verification/verification_decision_report.v1",
  "title": "Verification Decision Report",
  "description": "Schema for a verification decision report in the Axion verification system.",
  "type": "object",
  "required": [
    "report_id",
    "run_id",
    "scope",
    "proof_results",
    "coverage_gaps",
    "verdict",
    "verdict_rationale",
    "issued_at",
    "issued_by"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for this decision report."
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "description": "The run this report belongs to."
    },
    "scope": {
      "$ref": "#/definitions/scope",
      "description": "What was in scope for verification."
    },
    "proof_results": {
      "type": "array",
      "items": { "$ref": "#/definitions/proof_result" },
      "description": "Ordered list of proof outcomes."
    },
    "coverage_gaps": {
      "type": "array",
      "items": { "$ref": "#/definitions/coverage_gap" },
      "description": "Claims or requirements lacking proof."
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail", "conditional_pass", "deferred"],
      "description": "Final verification verdict."
    },
    "verdict_rationale": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable explanation of the verdict."
    },
    "issued_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the report was produced."
    },
    "issued_by": {
      "type": "string",
      "minLength": 1,
      "description": "Actor or system that produced the report."
    },
    "metadata": {
      "type": "object",
      "description": "Arbitrary key-value pairs for tooling."
    }
  },
  "definitions": {
    "scope": {
      "type": "object",
      "required": ["work_items"],
      "properties": {
        "work_items": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "List of work item IDs under verification."
        },
        "gate_id": {
          "type": "string",
          "description": "Gate that triggered verification."
        },
        "standards_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Standards that defined proof requirements."
        }
      },
      "additionalProperties": false
    },
    "proof_result": {
      "type": "object",
      "required": ["proof_id", "claim_id", "status", "strength_tier"],
      "properties": {
        "proof_id": {
          "type": "string",
          "minLength": 1
        },
        "claim_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "warn", "expired"]
        },
        "strength_tier": {
          "type": "string",
          "enum": ["assertion", "automated", "witnessed", "audited"]
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "coverage_gap": {
      "type": "object",
      "required": ["claim_id", "required_proof_class", "required_strength_tier", "reason"],
      "properties": {
        "claim_id": {
          "type": "string",
          "minLength": 1
        },
        "required_proof_class": {
          "type": "string"
        },
        "required_strength_tier": {
          "type": "string",
          "enum": ["assertion", "automated", "witnessed", "audited"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
