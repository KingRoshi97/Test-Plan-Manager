{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "verification_command_policy.v1",
    "type": "object",
    "required": ["policy_id", "schema_version", "rules"],
    "properties": {
      "policy_id": { "type": "string", "pattern": "^VERPOL-[A-Z0-9]{6,}$" },
      "schema_version": { "type": "string", "minLength": 1 },
      "rules": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["rule_id", "match", "decision"],
          "properties": {
            "rule_id": { "type": "string", "pattern": "^VRULE-[A-Z0-9_\\-]+$" },
            "match": {
              "type": "object",
              "required": ["pattern"],
              "properties": {
                "pattern": { "type": "string", "minLength": 1, "description": "Glob/regex pattern for command string" },
                "profiles": { "type": "array", "items": { "type": "string" } },
                "risk_classes": { "type": "array", "items": { "type": "string" } },
                "adapter_types": { "type": "array", "items": { "type": "string" } }
              },
              "additionalProperties": false
            },
            "decision": {
              "type": "object",
              "required": ["outcome"],
              "properties": {
                "outcome": { "type": "string", "enum": ["allow", "deny", "require_approval"] },
                "reason": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
}
