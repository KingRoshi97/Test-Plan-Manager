{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "telemetry_sink_policy.v1",
    "type": "object",
    "required": ["policy_id", "schema_version", "sinks", "redaction"],
    "properties": {
      "policy_id": { "type": "string", "pattern": "^TELPOL-[A-Z0-9]{6,}$" },
      "schema_version": { "type": "string", "minLength": 1 },

      "sinks": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["sink_id", "type", "enabled"],
          "properties": {
            "sink_id": { "type": "string", "minLength": 3 },
            "type": { "type": "string", "enum": ["local_file", "internal_http", "external_http"] },
            "enabled": { "type": "boolean" },
            "endpoint": { "type": "string" },
            "notes": { "type": "string" }
          },
          "additionalProperties": false
        }
      },

      "redaction": {
        "type": "object",
        "required": ["deny_keys", "deny_patterns", "external_strict_mode"],
        "properties": {
          "deny_keys": { "type": "array", "items": { "type": "string" } },
          "deny_patterns": { "type": "array", "items": { "type": "string" } },
          "external_strict_mode": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
}
