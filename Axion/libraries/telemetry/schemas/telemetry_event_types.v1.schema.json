{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "telemetry_event_types.v1",
    "type": "object",
    "required": ["registry_id", "schema_version", "types"],
    "properties": {
      "registry_id": { "type": "string", "minLength": 3 },
      "schema_version": { "type": "string", "minLength": 1 },
      "types": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["event_type", "schema_ref", "description"],
          "properties": {
            "event_type": { "type": "string", "minLength": 3 },
            "schema_ref": { "type": "string", "minLength": 3 },
            "description": { "type": "string", "minLength": 5 }
          },
          "additionalProperties": false
      }
      }
    },
    "additionalProperties": false
}
