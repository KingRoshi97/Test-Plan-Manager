{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "axion://schemas/telemetry/telemetry_decision_report.v1",
  "title": "Telemetry Decision Report",
  "type": "object",
  "required": [
    "report_id",
    "assessment_timestamp",
    "status",
    "metrics",
    "findings"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "description": "Unique identifier for this decision report.",
      "pattern": "^TDR-[A-Za-z0-9_-]{6,}$"
    },
    "assessment_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the health assessment."
    },
    "schema_version": {
      "type": "string",
      "description": "Version of the decision report schema.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "type": "string",
      "description": "Overall telemetry health status.",
      "enum": ["healthy", "degraded", "unhealthy"]
    },
    "metrics": {
      "type": "object",
      "description": "Evaluated health metrics.",
      "properties": {
        "signal_emission_rate": {
          "type": "number",
          "description": "Signals emitted per minute."
        },
        "delivery_success_rate": {
          "type": "number",
          "description": "Percentage of signals successfully delivered.",
          "minimum": 0,
          "maximum": 100
        },
        "dead_letter_count": {
          "type": "integer",
          "description": "Number of signals in the dead-letter sink.",
          "minimum": 0
        },
        "schema_validation_failure_rate": {
          "type": "number",
          "description": "Percentage of signals failing schema validation.",
          "minimum": 0,
          "maximum": 100
        }
      },
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "description": "List of findings from the health assessment.",
      "items": {
        "type": "object",
        "required": ["finding_id", "severity", "description"],
        "properties": {
          "finding_id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "critical"]
          },
          "description": {
            "type": "string"
          },
          "recommended_action": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "recommended_actions": {
      "type": "array",
      "description": "Aggregated recommended actions.",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}