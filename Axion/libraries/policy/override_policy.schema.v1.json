{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "axion://schemas/policy/override_policy.schema.v1.json",
  "title": "Axion Override Policy Schema v1",
  "type": "object",
  "required": ["version", "rules"],
  "properties": {
    "version": { "type": "string" },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/OverrideRule" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "OverrideRule": {
      "type": "object",
      "required": ["rule_id", "applies_to", "allowed", "requires_evidence", "expires_in_days"],
      "properties": {
        "rule_id": { "type": "string" },
        "applies_to": { "type": "string" },
        "allowed": { "type": "boolean" },
        "requires_evidence": { "type": "array", "items": { "type": "string" } },
        "expires_in_days": { "type": "integer", "minimum": 0 },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
