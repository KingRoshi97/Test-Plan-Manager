{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "override_decision.v1",
    "type": "object",
    "required": [
        "override_decision_id",
        "override_request_id",
        "run_id",
        "outcome",
        "approved_by",
        "decided_at",
        "expiry"
    ],
    "properties": {
        "override_decision_id": { "type": "string", "pattern": "^OVRDEC-[A-Z0-9]{6,}$" },
        "override_request_id": { "type": "string" },
        "run_id": { "type": "string" },
        "outcome": { "type": "string", "enum": ["approved", "denied"] },
        "approved_by": {
            "type": "object",
            "required": ["actor_id", "role"],
            "properties": {
                "actor_id": { "type": "string", "minLength": 2 },
                "role": { "type": "string", "enum": ["owner", "maintainer", "operator"] }
            },
            "additionalProperties": false
        },
        "conditions": {
            "type": "object",
            "description": "Optional constraints applied to approval (cap reduction, limited scope, etc.)",
            "additionalProperties": true
        },
        "decided_at": { "type": "string", "format": "date-time" },
        "expiry": {
            "type": "object",
            "required": ["expires_at"],
            "properties": { "expires_at": { "type": "string", "format": "date-time" } },
            "additionalProperties": false
        },
        "notes": { "type": "string" }
    },
    "additionalProperties": false
}
