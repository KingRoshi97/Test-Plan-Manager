{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "axion://schemas/system/SYS-02.policy_engine.schema.v1.json",
  "title": "SYS-02 — Policy Engine Schema (v1)",
  "type": "object",
  "required": ["version", "risk_class", "enforced", "overrides"],
  "properties": {
    "version": { "type": "string" },
    "risk_class": { "enum": ["LOW", "MED", "HIGH"] },
    "enforced": {
      "type": "object",
      "required": ["hard_stops", "required_evidence"],
      "properties": {
        "hard_stops": { "type": "array", "items": { "type": "string" } },
        "required_evidence": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["override_id", "applies_to", "allowed", "expires_at", "evidence"],
        "properties": {
          "override_id": { "type": "string" },
          "applies_to": { "type": "string" },
          "allowed": { "type": "boolean" },
          "expires_at": { "type": "string" },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "reason_code": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
