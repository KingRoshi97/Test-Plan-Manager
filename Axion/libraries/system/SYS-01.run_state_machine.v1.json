{
  "version": "1.0.0",
  "doc_id": "SYS-01",
  "description": "Authoritative run lifecycle + allowed transitions.",
  "states": ["queued", "running", "gated", "failed", "released", "closed"],
  "transitions": [
    { "from": "queued", "to": "running", "event": "run.start" },
    { "from": "running", "to": "gated", "event": "gate.fail_or_warn" },
    { "from": "running", "to": "failed", "event": "stage.fail" },
    { "from": "running", "to": "released", "event": "all_gates_pass" },
    { "from": "gated", "to": "running", "event": "operator.resume" },
    { "from": "gated", "to": "failed", "event": "operator.abort" },
    { "from": "released", "to": "closed", "event": "run.close" },
    { "from": "failed", "to": "closed", "event": "run.close" }
  ],
  "constraints": [
    {
      "rule_id": "SYS01-01",
      "name": "No direct queued->released",
      "forbidden_transition": { "from": "queued", "to": "released" }
    },
    {
      "rule_id": "SYS01-02",
      "name": "Closed is terminal",
      "terminal_state": "closed"
    }
  ]
}
