{
  "version": "1.0.0",
  "doc_id": "SYS-05",
  "description": "Notification routing for gate failures, approvals, and policy events.",
  "events": [
    { "event": "gate.fail", "severity": "high", "channels": ["console"] },
    { "event": "gate.warn", "severity": "med", "channels": ["console"] },
    { "event": "policy.override.applied", "severity": "med", "channels": ["console"] },
    { "event": "run.failed", "severity": "high", "channels": ["console"] },
    { "event": "run.released", "severity": "low", "channels": ["console"] }
  ],
  "constraints": [
    { "rule_id": "SYS05-01", "name": "All events must be declared", "enforced": true }
  ]
}
