{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0.0",
  "id": "notification_destinations.v1",
  "type": "object",
  "required": ["registry_id", "schema_version", "destinations"],
  "properties": {
    "registry_id": { "type": "string", "minLength": 3 },
    "schema_version": { "type": "string", "minLength": 1 },
    "destinations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["destination_id", "kind", "enabled"],
        "properties": {
          "destination_id": { "type": "string", "pattern": "^DEST-[A-Z0-9]{4,}$" },
          "kind": {
            "type": "string",
            "enum": ["console", "email", "slack", "webhook"]
          },
          "enabled": { "type": "boolean" },

          "config": {
            "type": "object",
            "description": "Kind-specific config; keep minimal here (secrets live elsewhere).",
            "properties": {
              "channel": { "type": "string" },
              "to": { "type": "array", "items": { "type": "string" } },
              "url_ref": { "type": "string", "description": "Reference to a secret, not a raw URL." }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
