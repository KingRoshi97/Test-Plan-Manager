{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0.0",
  "id": "project.v1",
  "type": "object",
  "required": [
    "project_id",
    "workspace_id",
    "name",
    "owners",
    "created_at",
    "updated_at",
    "enabled_profiles",
    "bindings"
  ],
  "properties": {
    "project_id": { "type": "string", "pattern": "^PRJ-[A-Z0-9]{6,}$" },
    "workspace_id": { "type": "string", "pattern": "^WS-[A-Z0-9]{6,}$" },
    "name": { "type": "string", "minLength": 2 },

    "owners": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "maintainers": { "type": "array", "items": { "type": "string" } },

    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },

    "enabled_profiles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^PROFILE-[A-Z0-9_]+$" }
    },

    "bindings": {
      "type": "object",
      "required": ["policy_set_id", "quota_set_id", "pin_policy_id"],
      "properties": {
        "policy_set_id": { "type": "string", "minLength": 3 },
        "quota_set_id": { "type": "string", "minLength": 3 },
        "pin_policy_id": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": false
    },

    "labels": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "additionalProperties": false
}
