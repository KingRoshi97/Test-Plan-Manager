{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "pin_set.v1",
    "type": "object",
    "required": ["pin_set_id", "pins", "resolved_at"],
    "properties": {
      "pin_set_id": { "type": "string", "pattern": "^PINSET-[A-Z0-9]{6,}$" },
      "resolved_at": { "type": "string", "format": "date-time" },

      "pins": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["target", "ref"],
          "properties": {
            "target": {
              "type": "string",
              "enum": [
                "library_index",
                "schema_registry",
                "standards_snapshot",
                "template_registry",
                "template_selection",
                "knowledge_selection",
                "policy_set",
                "quota_set",
                "adapter_profile"
              ]
            },
            "ref": {
              "type": "object",
              "required": ["version", "path"],
              "properties": {
                "version": { "type": "string", "minLength": 1 },
                "path": { "type": "string", "minLength": 3 },
                "hash": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
}
