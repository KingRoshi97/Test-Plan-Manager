{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0.0",
  "id": "notification_event_types.v1",
  "type": "object",
  "required": ["registry_id", "schema_version", "event_types"],
  "properties": {
    "registry_id": { "type": "string", "minLength": 3 },
    "schema_version": { "type": "string", "minLength": 1 },
    "event_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["event_type", "severity_levels"],
        "properties": {
          "event_type": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
          "severity_levels": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "enum": ["info", "warning", "error", "critical"] }
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
