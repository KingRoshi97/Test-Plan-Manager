{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "1.0.0",
  "id": "adapter_profile.v1",
  "type": "object",
  "required": ["adapter_profile_id", "adapter_type", "capabilities", "command_policy_id", "created_at", "updated_at", "owner"],
  "properties": {
    "adapter_profile_id": { "type": "string", "pattern": "^ADP-[A-Z0-9]{6,}$" },
    "adapter_type": {
      "type": "string",
      "enum": ["local", "replit", "ci", "container"]
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^CAP-[A-Z0-9_]+$" }
    },
    "command_policy_id": { "type": "string", "minLength": 3 },
    "constraints": {
      "type": "object",
      "properties": {
        "network_access": { "type": "string", "enum": ["none", "restricted", "full"] },
        "allowed_ports": { "type": "array", "items": { "type": "integer", "minimum": 1, "maximum": 65535 } },
        "max_processes": { "type": "integer", "minimum": 1 },
        "max_runtime_minutes": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "owner": { "type": "string", "minLength": 2 }
  },
  "additionalProperties": false
}
