{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "capability_registry.v1",
    "type": "object",
    "required": ["registry_id", "schema_version", "capabilities"],
    "properties": {
      "registry_id": { "type": "string", "minLength": 3 },
      "schema_version": { "type": "string", "minLength": 1 },
      "capabilities": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["capability_id", "name", "category"],
          "properties": {
            "capability_id": { "type": "string", "pattern": "^CAP-[A-Z0-9_]+$" },
            "name": { "type": "string", "minLength": 2 },
            "category": {
              "type": "string",
              "enum": ["filesystem", "process", "network", "runtime", "secrets", "ui", "git"]
            },
            "notes": { "type": "string" }
          },
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
}
