{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "axion://schemas/system/system_decision_report.v1",
  "title": "System Decision Report",
  "description": "Schema for an Axion system decision report as defined in SYS-2.",
  "type": "object",
  "required": [
    "report_id",
    "run_id",
    "timestamp",
    "resolution_steps",
    "pin_decisions",
    "capability_filter_results",
    "verdict"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "pattern": "^SDR-[A-Z0-9]{8,}$"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "resolution_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step_index", "component_id", "action", "reason"],
        "properties": {
          "step_index": { "type": "integer", "minimum": 0 },
          "component_id": { "type": "string" },
          "action": { "type": "string", "enum": ["resolved", "skipped", "failed", "deferred"] },
          "reason": { "type": "string" },
          "duration_ms": { "type": "number", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "pin_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_id", "pin_mode", "requested_version", "resolved_version", "pin_source"],
        "properties": {
          "artifact_id": { "type": "string" },
          "pin_mode": { "type": "string", "enum": ["pinned", "locked", "floating", "inherit"] },
          "requested_version": { "type": "string" },
          "resolved_version": { "type": "string" },
          "pin_source": { "type": "string", "enum": ["workspace", "project", "profile", "default"] }
        },
        "additionalProperties": false
      }
    },
    "capability_filter_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["component_id", "required_capabilities", "available_capabilities", "satisfied"],
        "properties": {
          "component_id": { "type": "string" },
          "required_capabilities": { "type": "array", "items": { "type": "string" } },
          "available_capabilities": { "type": "array", "items": { "type": "string" } },
          "satisfied": { "type": "boolean" },
          "excluded_reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "pass_with_warnings", "fail", "blocked"]
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
