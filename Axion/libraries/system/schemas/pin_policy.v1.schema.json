{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "pin_policy.v1",
    "type": "object",
    "required": ["pin_policy_id", "rules", "created_at", "updated_at", "owner"],
    "properties": {
      "pin_policy_id": { "type": "string", "pattern": "^PINPOL-[A-Z0-9]{6,}$" },

      "rules": {
        "type": "object",
        "required": ["allowed_targets", "lock_mode", "who_can_pin"],
        "properties": {
          "allowed_targets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "library_index",
                "schema_registry",
                "standards_snapshot",
                "template_registry",
                "template_selection",
                "knowledge_selection",
                "policy_set",
                "quota_set",
                "adapter_profile"
              ]
            }
          },

          "lock_mode": {
            "type": "string",
            "enum": ["open", "pinned_required", "locked"],
            "description": "open: allow latest; pinned_required: must pin at run start; locked: only pinned versions allowed, no changes"
          },

          "who_can_pin": {
            "type": "array",
            "items": { "type": "string", "enum": ["owner", "maintainer", "operator"] },
            "minItems": 1
          },

          "allow_run_level_overrides": { "type": "boolean", "default": false }
        },
        "additionalProperties": false
      },

      "created_at": { "type": "string", "format": "date-time" },
      "updated_at": { "type": "string", "format": "date-time" },
      "owner": { "type": "string", "minLength": 2 }
    },
    "additionalProperties": false
}
