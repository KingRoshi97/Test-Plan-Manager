{
  "version": "1.0.0",
  "doc_id": "SYS-04",
  "description": "Adapter capability discovery + selection rules (local/Replit/CI).",
  "adapters": [
    {
      "adapter_id": "local",
      "capabilities": ["filesystem", "spawn_process", "network_optional", "git"],
      "limits": { "max_runtime_seconds": 1800, "max_output_mb": 50 }
    },
    {
      "adapter_id": "replit",
      "capabilities": ["filesystem", "spawn_process", "network_optional"],
      "limits": { "max_runtime_seconds": 1200, "max_output_mb": 25 }
    },
    {
      "adapter_id": "ci",
      "capabilities": ["filesystem", "spawn_process", "network", "git"],
      "limits": { "max_runtime_seconds": 2400, "max_output_mb": 100 }
    }
  ],
  "selection": {
    "default_adapter": "local",
    "prefer_order": ["ci", "local", "replit"],
    "require_capabilities": {
      "verification.command.ran": ["spawn_process"],
      "kit.package": ["filesystem"]
    }
  }
}
