{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "template_definition.v1",
    "type": "object",
    "required": [
      "template_id",
      "title",
      "category",
      "version",
      "template_type",
      "required_inputs",
      "placeholders",
      "output",
      "created_at",
      "updated_at",
      "owner"
    ],
    "properties": {
      "template_id": { "type": "string", "pattern": "^TMP-[A-Z0-9]{2,3}-\\d{2}$" },
      "title": { "type": "string", "minLength": 3 },

     "category": {
       "type": "string",
       "enum": [
         "PRODUCT_DEFINITION",
         "APPLICATION_BUILD",
         "SYSTEM_ARCHITECTURE",
         "DATA_AND_INFORMATION",
         "EXPERIENCE_DESIGN",
         "INTEGRATIONS_AND_EXTERNAL",
         "SECURITY_PRIVACY_COMPLIANCE",
         "OPERATIONS_AND_RELIABILITY"
       ]
     },

     "subcategory": { "type": "string" },

     "version": { "type": "string", "minLength": 1 },
  "template_type": { "type": "string", "enum": ["doc_template", "schema_template", "checklist_template"] },

  "required_inputs": {
    "type": "array",
    "minItems": 1,
    "items": { "type": "string", "minLength": 2 },
    "description": "Contract IDs required to render (CANONICAL_SPEC, STANDARDS_SNAPSHOT, etc.)"
  },

  "placeholders": {
    "type": "array",
    "minItems": 1,
    "items": { "$ref": "#/$defs/placeholder" }
  },

  "output": {
    "type": "object",
    "required": ["contract_id", "default_path"],
    "properties": {
      "contract_id": { "type": "string", "minLength": 2 },
      "default_path": { "type": "string", "minLength": 3 },
      "format": { "type": "string", "enum": ["md", "json", "yaml"] }
    },
    "additionalProperties": false
  },

  "completeness": {
    "type": "object",
    "properties": {
      "required_sections": { "type": "array", "items": { "type": "string" } },
      "required_placeholder_ids": { "type": "array", "items": { "type": "string" } }
    },
    "additionalProperties": false
  },

   "created_at": { "type": "string", "format": "date-time" },
   "updated_at": { "type": "string", "format": "date-time" },
   "owner": { "type": "string", "minLength": 2 }
 },

 "$defs": {
  "placeholder": {
          "type": "object",
          "required": ["placeholder_id", "label", "kind", "required"],
          "properties": {
            "placeholder_id": { "type": "string", "pattern": "^PH-[A-Z0-9_\\-]+$" },
            "label": { "type": "string", "minLength": 2 },

           "kind": { "type": "string", "enum": ["text", "table", "list", "json_block", "code_block"] },
           "required": { "type": "boolean" },

    "source": {
      "type": "object",
      "description": "Where content is derived from (canonical, standards, knowledge, or computed).",
      "properties": {
        "from": { "type": "string", "enum": ["canonical", "standards", "knowledge", "computed", "manual"] },
        "pointer": { "type": "string" }
      },
      "additionalProperties": false
    },

            "constraints": {
              "type": "object",
              "properties": {
                "max_words": { "type": "integer", "minimum": 0 },
                "format_hint": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
      }
    },

    "additionalProperties": false
}
