{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "standards_snapshot.v1",
    "type": "object",
    "required": [
      "snapshot_id",
      "run_id",
      "resolver_version",
      "resolved_packs",
      "resolved_rules",
      "created_at"
    ],
    "properties": {
      "snapshot_id": { "type": "string", "pattern": "^STDSNAP-[A-Z0-9]{6,}$" },
      "run_id": { "type": "string" },
      "resolver_version": { "type": "string", "minLength": 1 },
      "resolved_packs": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["pack_id", "version", "path"],
          "properties": {
            "pack_id": { "type": "string" },
            "version": { "type": "string" },
            "path": { "type": "string" },
            "hash": { "type": "string" },
            "maturity": { "type": "string", "enum": ["draft", "reviewed", "verified", "golden"] }
          },
          "additionalProperties": false
        }
      },
      "resolved_rules": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["pack_id", "pack_version", "rule_id", "type", "severity", "statement"],
          "properties": {
            "pack_id": { "type": "string" },
            "pack_version": { "type": "string" },
            "rule_id": { "type": "string" },
            "type": { "type": "string" },
            "severity": { "type": "string" },
            "statement": { "type": "string" },
            "applies_to": { "type": "object", "additionalProperties": true },
            "evidence": { "type": "object", "additionalProperties": true }
          },
          "additionalProperties": false
        }
      },
      "conflicts": {
        "type": "array",
        "items": { "type": "object", "additionalProperties": true }
      },
      "effective_settings": {
        "type": "object",
        "description": "Optional derived defaults/settings merged from packs",
        "additionalProperties": true
      },
      "created_at": { "type": "string", "format": "date-time" }
    },
    "additionalProperties": false
}