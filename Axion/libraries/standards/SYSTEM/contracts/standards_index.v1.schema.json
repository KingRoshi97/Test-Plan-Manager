{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "standards_index.v1",
    "type": "object",
    "required": ["index_id", "schema_version", "packs"],
    "properties": {
      "index_id": { "type": "string", "minLength": 3 },
      "schema_version": { "type": "string", "minLength": 1 },
      "packs": {
        "type": "array",
        "minItems": 1,
        "items": { "$ref": "standards_index_entry.v1.schema.json" }
      }
    },
    "additionalProperties": false
}