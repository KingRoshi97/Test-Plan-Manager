{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "schema_version": "1.0.0",
    "id": "standards_pack.v1",
    "type": "object",
    "required": [
      "pack_id",
      "title",
      "version",
      "scope",
      "rules",
      "created_at",
      "updated_at",
      "owner"
    ],
    "properties": {
      "pack_id": { "type": "string", "pattern": "^STD-[A-Z0-9_\\-]+$" },
      "title": { "type": "string", "minLength": 3 },
      "version": { "type": "string", "minLength": 1 },
      "scope": { "$ref": "#/$defs/scope" },
      "rules": {
        "type": "array",
        "minItems": 1,
        "items": { "$ref": "#/$defs/rule" }
      },
      "created_at": { "type": "string", "format": "date-time" },
      "updated_at": { "type": "string", "format": "date-time" },
      "owner": { "type": "string", "minLength": 2 }
    },
    "$defs": {
      "scope": {
        "type": "object",
        "required": ["profiles", "risk_classes"],
        "properties": {
          "profiles": {
            "type": "array",
            "items": { "type": "string", "pattern": "^PROFILE-[A-Z0-9_]+$" },
            "minItems": 1
          },
          "risk_classes": {
            "type": "array",
            "items": { "type": "string", "enum": ["PROTOTYPE", "PROD", "COMPLIANCE"] },
            "minItems": 1
          },
          "stacks": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional: technology families (react, node, postgres, etc.)"
          },
          "domains": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional: canonical domains (auth, payments, media, etc.)"
          }
        },
        "additionalProperties": false
      },
      "rule": {
        "type": "object",
        "required": ["rule_id", "type", "severity", "statement"],
        "properties": {
          "rule_id": { "type": "string", "pattern": "^RULE-[A-Z0-9_\\-]+$" },
          "type": {
            "type": "string",
            "enum": ["constraint", "default", "required_artifact", "verification", "naming", "layout"]
          },
          "severity": { "type": "string", "enum": ["must", "should", "must_not"] },
          "statement": { "type": "string", "minLength": 5 },
          "applies_to": {
            "type": "object",
            "description": "Optional narrower applicability within the pack scope",
            "properties": {
              "targets": { "type": "array", "items": { "type": "string" } },
              "entity_types": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          },
          "evidence": {
            "type": "object",
            "description": "Optional: what evidence should exist when checking this rule",
            "properties": {
              "artifact_contract_ids": { "type": "array", "items": { "type": "string" } },
              "proof_requirements": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
}