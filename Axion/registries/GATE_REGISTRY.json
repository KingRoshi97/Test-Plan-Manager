{
  "version": "1.0.0",
  "gates": [
    {
      "gate_id": "G1_INTAKE_VALIDITY",
      "stage_id": "S2_VALIDATE_INTAKE",
      "severity": "hard",
      "checks": [
        { "op": "file_exists", "path": ".axion/runs/{{run_id}}/intake/validation_result.json" },
        { "op": "json_valid", "path": ".axion/runs/{{run_id}}/intake/validation_result.json" }
      ]
    },
    {
      "gate_id": "G2_CANONICAL_INTEGRITY",
      "stage_id": "S4_VALIDATE_CANONICAL",
      "severity": "hard",
      "checks": [
        { "op": "file_exists", "path": ".axion/runs/{{run_id}}/canonical/canonical_spec.json" },
        { "op": "json_valid", "path": ".axion/runs/{{run_id}}/canonical/canonical_spec.json" },
        { "op": "json_has", "path": ".axion/runs/{{run_id}}/canonical/canonical_spec.json", "pointer": "/run_id" }
      ]
    },
    {
      "gate_id": "G3_STANDARDS_RESOLVED",
      "stage_id": "S5_RESOLVE_STANDARDS",
      "severity": "hard",
      "checks": [
        { "op": "file_exists", "path": ".axion/runs/{{run_id}}/standards/resolved_standards_snapshot.json" },
        { "op": "json_valid", "path": ".axion/runs/{{run_id}}/standards/resolved_standards_snapshot.json" }
      ]
    },
    {
      "gate_id": "G4_TEMPLATE_SELECTION",
      "stage_id": "S6_SELECT_TEMPLATES",
      "severity": "hard",
      "checks": [
        { "op": "file_exists", "path": ".axion/runs/{{run_id}}/templates/selection_result.json" },
        { "op": "json_valid", "path": ".axion/runs/{{run_id}}/templates/selection_result.json" },
        { "op": "json_has", "path": ".axion/runs/{{run_id}}/templates/selection_result.json", "pointer": "/selected_templates" }
      ]
    },
    {
      "gate_id": "G5_TEMPLATE_COMPLETENESS",
      "stage_id": "S7_RENDER_DOCS",
      "severity": "hard",
      "checks": [
        { "op": "file_exists", "path": ".axion/runs/{{run_id}}/templates/render_report.json" },
        { "op": "json_valid", "path": ".axion/runs/{{run_id}}/templates/render_report.json" },
        { "op": "file_exists", "path": ".axion/runs/{{run_id}}/templates/template_completeness_report.json" },
        { "op": "json_valid", "path": ".axion/runs/{{run_id}}/templates/template_completeness_report.json" },
        { "op": "json_eq", "path": ".axion/runs/{{run_id}}/templates/template_completeness_report.json", "pointer": "/pass", "expected": true }
      ]
    },
    {
      "gate_id": "G6_PLAN_COVERAGE",
      "stage_id": "S8_BUILD_PLAN",
      "severity": "hard",
      "checks": [
        { "op": "file_exists", "path": ".axion/runs/{{run_id}}/planning/coverage_report.json" },
        { "op": "json_valid", "path": ".axion/runs/{{run_id}}/planning/coverage_report.json" },
        { "op": "coverage_gte", "path": ".axion/runs/{{run_id}}/planning/coverage_report.json", "pointer": "/coverage_percent", "min": 100 }
      ]
    },
    {
      "gate_id": "G7_VERIFICATION",
      "stage_id": "S9_VERIFY_PROOF",
      "severity": "hard",
      "checks": [
        { "op": "file_exists", "path": ".axion/runs/{{run_id}}/verification/verification_run_result.json" },
        { "op": "json_valid", "path": ".axion/runs/{{run_id}}/verification/verification_run_result.json" },
        { "op": "file_exists", "path": ".axion/runs/{{run_id}}/proof/proof_ledger.jsonl" },
        { "op": "file_exists", "path": ".axion/runs/{{run_id}}/verification/completion_report.json" },
        { "op": "json_valid", "path": ".axion/runs/{{run_id}}/verification/completion_report.json" }
      ]
    },
    {
      "gate_id": "G8_PACKAGE_INTEGRITY",
      "stage_id": "S10_PACKAGE",
      "severity": "hard",
      "checks": [
        { "op": "file_exists", "path": ".axion/runs/{{run_id}}/kit/packaging_manifest.json" },
        { "op": "json_valid", "path": ".axion/runs/{{run_id}}/kit/packaging_manifest.json" },
        {
          "op": "verify_hash_manifest",
          "manifest_path": ".axion/runs/{{run_id}}/kit/packaging_manifest.json",
          "bundle_root": ".axion/runs/{{run_id}}/kit/bundle"
        }
      ]
    }
  ]
}
