{
  "version": "1.0.0",
  "stage_id": "S4_CANONICAL_BUILD",
  "consumes": ["submission_record", "validation_result", "resolved_standards_snapshot"],
  "produces": ["canonical_spec"],
  "required_inputs": [
    {
      "artifact_id": "submission_record",
      "path": ".axion/runs/<run_id>/intake/submission_record.json"
    },
    {
      "artifact_id": "validation_result",
      "path": ".axion/runs/<run_id>/intake/validation_result.json"
    },
    {
      "artifact_id": "resolved_standards_snapshot",
      "path": ".axion/runs/<run_id>/standards/resolved_standards_snapshot.json"
    }
  ],
  "required_outputs": [
    {
      "artifact_id": "canonical_spec",
      "path": ".axion/runs/<run_id>/canonical/canonical_spec.json"
    }
  ],
  "optional_outputs": []
}
