{
  "version": "1.0.0",
  "stage_id": "S5_TEMPLATE_SELECTION",
  "consumes": ["canonical_spec", "resolved_standards_snapshot"],
  "produces": ["template_selection_result"],
  "required_inputs": [
    {
      "artifact_id": "canonical_spec",
      "path": ".axion/runs/<run_id>/canonical/canonical_spec.json"
    },
    {
      "artifact_id": "resolved_standards_snapshot",
      "path": ".axion/runs/<run_id>/standards/resolved_standards_snapshot.json"
    }
  ],
  "required_outputs": [
    {
      "artifact_id": "template_selection_result",
      "path": ".axion/runs/<run_id>/templates/selection_result.json"
    }
  ],
  "optional_outputs": []
}
