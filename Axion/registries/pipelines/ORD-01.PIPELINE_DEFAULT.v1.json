{
  "version": "1.0.0",
  "pipeline_id": "PIPELINE_DEFAULT",
  "description": "Default Axion pipeline (S0..S10) with gate points.",
  "stages": [
    {
      "stage_id": "S0_INIT",
      "name": "Init",
      "consumes": [],
      "produces": ["run_manifest"],
      "outputs": [
        { "artifact_id": "run_manifest", "path": ".axion/runs/<run_id>/run_manifest.json", "role": "manifest" }
      ]
    },
    {
      "stage_id": "S1_INGEST_NORMALIZE",
      "name": "Ingest + Normalize",
      "consumes": ["raw_submission"],
      "produces": ["submission_record"],
      "outputs": [
        { "artifact_id": "submission_record", "path": ".axion/runs/<run_id>/intake/submission_record.json", "role": "intake" }
      ]
    },
    {
      "stage_id": "S2_INTAKE_VALIDATION",
      "name": "Intake Validation",
      "consumes": ["submission_record"],
      "produces": ["validation_result"],
      "outputs": [
        { "artifact_id": "validation_result", "path": ".axion/runs/<run_id>/intake/validation_result.json", "role": "intake" }
      ]
    },
    {
      "stage_id": "S3_STANDARDS_RESOLUTION",
      "name": "Standards Resolution",
      "consumes": ["validation_result", "submission_record"],
      "produces": ["resolved_standards_snapshot"],
      "outputs": [
        { "artifact_id": "resolved_standards_snapshot", "path": ".axion/runs/<run_id>/standards/resolved_standards_snapshot.json", "role": "standards" }
      ]
    },
    {
      "stage_id": "S4_CANONICAL_BUILD",
      "name": "Canonical Build",
      "consumes": ["validation_result", "submission_record", "resolved_standards_snapshot"],
      "produces": ["canonical_spec"],
      "outputs": [
        { "artifact_id": "canonical_spec", "path": ".axion/runs/<run_id>/canonical/canonical_spec.json", "role": "canonical" }
      ]
    },
    {
      "stage_id": "S5_TEMPLATE_SELECTION",
      "name": "Template Selection",
      "consumes": ["canonical_spec", "resolved_standards_snapshot"],
      "produces": ["template_selection_result"],
      "outputs": [
        { "artifact_id": "template_selection_result", "path": ".axion/runs/<run_id>/templates/selection_result.json", "role": "templates" }
      ]
    },
    {
      "stage_id": "S6_PLAN_GENERATION",
      "name": "Plan Generation",
      "consumes": ["canonical_spec", "template_selection_result"],
      "produces": ["work_breakdown", "acceptance_map", "build_plan"],
      "outputs": [
        { "artifact_id": "work_breakdown", "path": ".axion/runs/<run_id>/planning/work_breakdown.json", "role": "planning" },
        { "artifact_id": "acceptance_map", "path": ".axion/runs/<run_id>/planning/acceptance_map.json", "role": "planning" },
        { "artifact_id": "build_plan", "path": ".axion/runs/<run_id>/planning/build_plan.json", "role": "planning" }
      ]
    },
    {
      "stage_id": "S7_TEMPLATE_FILL",
      "name": "Template Fill",
      "consumes": ["canonical_spec", "resolved_standards_snapshot", "template_selection_result", "work_breakdown", "acceptance_map"],
      "produces": ["render_envelopes", "render_report"],
      "outputs": [
        { "artifact_id": "render_report", "path": ".axion/runs/<run_id>/templates/render_report.json", "role": "templates" }
      ]
    },
    {
      "stage_id": "S8_GATE_EVALUATION",
      "name": "Gate Evaluation",
      "consumes": ["validation_result", "canonical_spec", "template_selection_result", "render_report", "work_breakdown", "acceptance_map", "build_plan"],
      "produces": ["gate_reports"],
      "outputs": [
        { "artifact_id": "gate_reports", "path": ".axion/runs/<run_id>/gates/gate_reports.json", "role": "gates" }
      ]
    },
    {
      "stage_id": "S9_KIT_PACKAGE",
      "name": "Kit Package",
      "consumes": ["canonical_spec", "resolved_standards_snapshot", "template_selection_result", "render_report", "work_breakdown", "acceptance_map", "build_plan", "gate_reports"],
      "produces": ["kit_manifest", "kit_bundle"],
      "outputs": [
        { "artifact_id": "kit_manifest", "path": ".axion/runs/<run_id>/kit/packaging_manifest.json", "role": "kit" }
      ]
    },
    {
      "stage_id": "S10_CLOSE",
      "name": "Close",
      "consumes": ["kit_manifest"],
      "produces": ["run_closed"],
      "outputs": [
        { "artifact_id": "run_closed", "path": ".axion/runs/<run_id>/close/closed.json", "role": "manifest" }
      ]
    }
  ],
  "stage_order": [
    "S0_INIT",
    "S1_INGEST_NORMALIZE",
    "S2_INTAKE_VALIDATION",
    "S3_STANDARDS_RESOLUTION",
    "S4_CANONICAL_BUILD",
    "S5_TEMPLATE_SELECTION",
    "S6_PLAN_GENERATION",
    "S7_TEMPLATE_FILL",
    "S8_GATE_EVALUATION",
    "S9_KIT_PACKAGE",
    "S10_CLOSE"
  ],
  "gates": [
    { "gate_id": "G1_INTAKE_VALIDITY", "after_stage_id": "S2_INTAKE_VALIDATION", "required": true },
    { "gate_id": "G3_STANDARDS_RESOLVED", "after_stage_id": "S3_STANDARDS_RESOLUTION", "required": true },
    { "gate_id": "G2_CANONICAL_INTEGRITY", "after_stage_id": "S4_CANONICAL_BUILD", "required": true },
    { "gate_id": "G4_TEMPLATE_SELECTION", "after_stage_id": "S5_TEMPLATE_SELECTION", "required": true },
    { "gate_id": "G6_PLAN_COVERAGE", "after_stage_id": "S6_PLAN_GENERATION", "required": true },
    { "gate_id": "G5_TEMPLATE_COMPLETENESS", "after_stage_id": "S7_TEMPLATE_FILL", "required": true },
    { "gate_id": "G7_VERIFICATION", "after_stage_id": "S8_GATE_EVALUATION", "required": true }
  ],
  "activation_rules": []
}
