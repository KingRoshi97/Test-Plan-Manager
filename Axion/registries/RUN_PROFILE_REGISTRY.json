  "mode_overlays": [
    {
      "mode_id": "fast",
      "description": "Skip non-critical gates for rapid iteration",
      "gate_overrides": {
        "G4_TEMPLATE_SELECTION": false,
        "G5_TEMPLATE_COMPLETENESS": false,
        "G7_VERIFICATION": false
      },
      "stage_overrides": {},
      "proof_overrides": {
        "remove": ["manual_attestation", "verification_log"]
      }
    },
    {
      "mode_id": "strict",
      "description": "All gates enforced, all proofs required",
      "gate_overrides": {
        "G7_VERIFICATION": true
      },
      "stage_overrides": {},
      "proof_overrides": {
        "add": ["verification_log", "manual_attestation"]
      }
    },
    {
      "mode_id": "audit",
      "description": "Compliance-oriented mode with full evidence trail",
      "gate_overrides": {
        "G7_VERIFICATION": true
      },
      "stage_overrides": {},
      "proof_overrides": {
        "add": ["verification_log", "manual_attestation", "compliance_attestation"]
      }
    }
