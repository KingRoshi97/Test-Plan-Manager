run = "cowsay Configure me!"
entrypoint = "README.md"
modules = ["nodejs-20", "postgresql-16"]

[nix]
channel = "stable-24_11"
packages = ["cowsay"]

[agent]
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0", "javascript_anthropic_ai_integrations:2.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5173
externalPort = 5173

[userenv]

[userenv.shared]
AXION_IA_CONCURRENCY = "10"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
