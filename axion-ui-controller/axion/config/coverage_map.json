{
  "version": "1.0.0",
  "description": "Maps RPBS/REBS blocks to core modules for derivation enforcement",
  "blocks": {
    "TENANCY_ORG_MODEL": {
      "source": "RPBS",
      "source_section": "§21 Tenancy / Organization Model",
      "required_for": ["contracts", "auth", "backend", "database", "state", "frontend", "fullstack"],
      "notes": "Must be acknowledged even if N/A"
    },
    "ACTORS_PERMISSIONS": {
      "source": "RPBS",
      "source_section": "§3 Actors & Permission Intents",
      "required_for": ["contracts", "auth", "backend", "database", "state", "frontend", "fullstack"],
      "notes": "Permission intents must align with auth model"
    },
    "CORE_OBJECTS": {
      "source": "RPBS",
      "source_section": "§4 Core Objects Glossary",
      "required_for": ["contracts", "database", "backend", "state", "frontend", "fullstack"],
      "notes": "Entity definitions drive schema and API design"
    },
    "NON_FUNCTIONAL_PROFILE": {
      "source": "RPBS",
      "source_section": "§7 Non-Functional Profile",
      "required_for": ["systems", "backend", "database", "frontend", "fullstack"],
      "notes": "Must be reflected in constraints"
    },
    "BILLING_ENTITLEMENTS": {
      "source": "RPBS",
      "source_section": "§14 Billing, Plans, and Entitlements",
      "required_for": ["contracts", "backend", "frontend", "fullstack"],
      "notes": "If billing disabled, must say N/A"
    },
    "NOTIFICATIONS_MATRIX": {
      "source": "RPBS",
      "source_section": "§11 Notifications & Messaging Matrix",
      "required_for": ["backend", "frontend", "fullstack"],
      "notes": "If enabled, must reflect delivery policy"
    },
    "UPLOADS_MEDIA": {
      "source": "RPBS",
      "source_section": "§13 File / Media Handling",
      "required_for": ["contracts", "backend", "frontend", "fullstack"],
      "notes": "If uploads enabled, cannot remain UNKNOWN"
    },
    "PRIVACY_CONTROLS": {
      "source": "RPBS",
      "source_section": "§29 User Privacy Controls, Consent, and Account Lifecycle",
      "required_for": ["auth", "backend", "database", "frontend"],
      "notes": "Deletion/export/consent rules"
    },
    "PUBLIC_API": {
      "source": "RPBS",
      "source_section": "§22 Public API / Developer Platform",
      "required_for": ["contracts", "backend", "systems"],
      "notes": "If enabled, versioning required"
    },
    "STACK_SELECTION_POLICY": {
      "source": "REBS",
      "source_section": "§1 Stack Selection Policy",
      "required_for": ["systems", "contracts", "backend", "frontend", "fullstack"],
      "notes": "Must not contradict selected stack/language"
    },
    "OPEN_QUESTIONS": {
      "source": "RPBS",
      "source_section": "§34 OPEN_QUESTIONS",
      "required_for": ["contracts", "auth", "backend", "database", "state", "frontend", "fullstack", "systems"],
      "notes": "Module must reference impacting Q-IDs"
    }
  },
  "core_modules": ["contracts", "database", "auth", "backend", "state", "frontend", "fullstack", "systems"],
  "enforcement_rules": {
    "derivation_block_required": true,
    "unknown_requires_question": true,
    "capability_mention_required": true
  }
}
