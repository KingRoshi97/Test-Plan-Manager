{
  "version": "2.1",
  "description": "Protected paths that MUST NOT be touched by hygiene commands (reorg, consolidate, reset, purge)",
  "patterns": [
    "server/db/schema.ts",
    "server/db/client.ts",
    "migrations/**",
    "src/theme/**",
    "src/assets/brand/**",
    "assets/**",
    "roshi/**",
    "scripts/**",
    "assembler/**",
    "shared/schema.ts",
    "drizzle.config.ts",
    "package.json",
    "package-lock.json",
    "tsconfig.json",
    "vite.config.ts",
    ".replit",
    "replit.nix",
    "replit.md"
  ],
  "categories": {
    "database": [
      "server/db/schema.ts",
      "server/db/client.ts",
      "migrations/**",
      "shared/schema.ts",
      "drizzle.config.ts"
    ],
    "brand": [
      "src/theme/**",
      "src/assets/brand/**",
      "assets/**"
    ],
    "engine": [
      "roshi/**",
      "scripts/**",
      "assembler/**"
    ],
    "config": [
      "package.json",
      "package-lock.json",
      "tsconfig.json",
      "vite.config.ts",
      ".replit",
      "replit.nix",
      "replit.md"
    ]
  }
}
